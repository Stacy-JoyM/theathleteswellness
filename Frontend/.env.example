# Frontend configuration (Vite)
# Copy this file to .env.local for local overrides
# Vite exposes variables prefixed with VITE_ to the client
#
# LOCAL: Leave VITE_API_BASE_URL unset. Run "npm run dev" from project root -
# the server serves both frontend and API on port 5000 (same origin).
#
# LATER (Fly.io etc.): Set when frontend and backend are on different hosts:
VITE_API_BASE_URL=http://127.0.0.1:5000